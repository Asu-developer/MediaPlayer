<Window x:Class="MuzikCalar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Music" Height="500" Width="700" Background="#FF404040">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Üst -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBox x:Name="txtKlasor" Width="400" Height="30" Margin="0,0,10,0" Background="#FF5F5F5F" Foreground="White" FontSize="16"/>
            <Button Content="Klasör Seç" Width="120" Click="BtnKlasorSec_Click"/>
        </StackPanel>

        <!-- Liste -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>

            <!-- Şarkı listesi -->
            <ListBox x:Name="lstSarkilar"
                     Grid.Column="0"
                     Margin="0,0,45,60"
                     MouseDoubleClick="LstSarkilar_MouseDoubleClick"
                     Background="#FF5F5F5F" 
                     Grid.ColumnSpan="2" 
                     Foreground="White"
                     FontSize="16"
                     FontFamily="Segoe UI">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Height" Value="32"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Volume -->
            <Grid Grid.Column="1" Margin="0,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="🔊"
                           FontSize="20"
                           HorizontalAlignment="Left"
                           Margin="23,2,0,3" 
                           Foreground="White"/>
                <Slider x:Name="sliderVolume"
                        Minimum="0" Maximum="1" Value="0.5"
                        Orientation="Vertical"
                        HorizontalAlignment="Left"
                        Width="25"
                        ValueChanged="SliderVolume_ValueChanged" 
                        Margin="25,0,0,53" 
                        Grid.Row="1"/>
            </Grid>

            <!-- Progress + Zaman Bilgileri -->
            <Grid Grid.Column="0" 
                  VerticalAlignment="Bottom" 
                  Margin="128,0,75,10" 
                  Height="38">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtCurrentTime" 
                           Text="0:00" 
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,8,0"/>

                <Slider x:Name="sliderProgress" 
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Height="20"
                        PreviewMouseDown="SliderProgress_PreviewMouseDown"
                        PreviewMouseUp="SliderProgress_PreviewMouseUp"
                        ValueChanged="SliderProgress_ValueChanged"/>
                <!-- ← YENİ EKLENDİ -->

                <TextBlock x:Name="txtTotalTime" 
                           Text="0:00" 
                           Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="8,0,0,0"/>
            </Grid>
        </Grid>

        <!-- Kontroller -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="◀ Önceki" Width="100" Height="50" Margin="5" Click="BtnOnceki_Click"/>
            <Button x:Name="btnOynat"
                    Content="▶ Oynat"
                    Width="100" 
                    Height="50" 
                    Margin="5" 
                    Click="BtnOynat_Click"/>
            <Button Content="Sonraki ▶" Width="100" Height="50" Margin="5" Click="BtnSonraki_Click"/>
        </StackPanel>

        <MediaElement x:Name="mediaPlayer" Visibility="Collapsed"/>
    </Grid>
</Window>