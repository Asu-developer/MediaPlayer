<Window x:Class="MuzikCalar.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Müzik Çalar Pro" Height="650" Width="850" Background="#121212"
        MinWidth="650" MinHeight="500">

    <Window.Resources>
        <Style x:Key="ModernShuffleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="10" BorderThickness="1" BorderBrush="#333">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1DB954"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1DB954"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="#606060"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#707070"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Background="#333" Width="4" CornerRadius="2"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Background="Transparent" IsHitTestVisible="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Background="Transparent" IsHitTestVisible="False"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16" Background="#1DB954" BorderBrush="White" BorderThickness="2">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}" 
                                                        Stroke="{TemplateBinding BorderBrush}" 
                                                        StrokeThickness="{TemplateBinding BorderThickness}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>
            
            <TextBox x:Name="txtKlasor" Height="35" Background="#252525" Foreground="White" BorderThickness="0" Padding="10,5" VerticalContentAlignment="Center" IsReadOnly="True"/>
            
            <Button Content="Klasör Seç" Grid.Column="1" Width="120" Margin="10,0,10,0" Click="BtnKlasorSec_Click" Cursor="Hand"/>
            
            <Grid Grid.Column="2">
                <TextBox x:Name="txtArama" Height="35" Background="#252525" Foreground="White" BorderThickness="0" Padding="10,5,35,5" VerticalContentAlignment="Center" TextChanged="TxtArama_TextChanged"/>
                
                <TextBlock Text="Arama yapın..." Foreground="#666" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=txtArama}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                
                <TextBlock Text="🔍" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0" Foreground="#888" IsHitTestVisible="False"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="lstSarkilar" Background="#1E1E1E" Foreground="#DDD" BorderThickness="0" 
                     MouseDoubleClick="LstSarkilar_MouseDoubleClick" 
                     PreviewMouseDown="LstSarkilar_PreviewMouseDown"
                     LostFocus="LstSarkilar_LostFocus"
                     PreviewMouseWheel="LstSarkilar_PreviewMouseWheel">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Height" Value="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Setter Property="FontSize" Value="{Binding ItemFontSize, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="Foreground" Value="#DDD"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="border" Background="Transparent" Padding="10,5">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#87CEEB"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Playing">
                                            <Setter TargetName="border" Property="Background" Value="#D3D3D3"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <Grid Grid.Column="1" VerticalAlignment="Stretch" Margin="5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="🔊" Foreground="White" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <Slider x:Name="sliderVolume" Grid.Row="1" Orientation="Vertical" 
                        Minimum="0" Maximum="1" Value="0.5" 
                        HorizontalAlignment="Center" ValueChanged="SliderVolume_ValueChanged"
                        Style="{StaticResource VolumeSliderStyle}"/>
            </Grid>
        </Grid>

        <Canvas x:Name="canvasSiri" Grid.Row="2" Background="Transparent" IsHitTestVisible="False" ClipToBounds="True">
            <Polyline x:Name="waveLine" Stroke="White" StrokeThickness="2" />
        </Canvas>

        <Grid Grid.Row="3" Margin="0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="txtCurrentTime" Text="00:00" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <Slider x:Name="sliderProgress" Grid.Column="1" Margin="10,0" PreviewMouseDown="SliderProgress_PreviewMouseDown" PreviewMouseUp="SliderProgress_PreviewMouseUp" ValueChanged="SliderProgress_ValueChanged"/>
            <TextBlock x:Name="txtTotalTime" Text="00:00" Grid.Column="2" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="⏮" Width="55" Height="45" Margin="5" Click="BtnOnceki_Click"/>
            <Button x:Name="btnOynat" Content="▶" Width="70" Height="45" Margin="5" Click="BtnOynat_Click" FontSize="18"/>
            <Button Content="⏭" Width="55" Height="45" Margin="5" Click="BtnSonraki_Click"/>

            <ToggleButton x:Name="chkShuffle" Content="🔀 Karıştır" Style="{StaticResource ModernShuffleStyle}" 
                          Width="110" Height="45" Margin="25,5,5,5" IsChecked="False"/>
        </StackPanel>

        <MediaElement x:Name="mediaPlayer" 
              LoadedBehavior="Manual" 
              UnloadedBehavior="Close" 
              Visibility="Collapsed"/>
    </Grid>
</Window>